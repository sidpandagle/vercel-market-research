# Resend — email delivery (https://resend.com/api-keys)
# Domain neographanalytics.com must be verified in Resend dashboard to send from support@neographanalytics.com
RESEND_API_KEY=your_resend_api_key_here

# API Configuration
# Base URL for the backend API (reports, forms, search, categories)
# For local development: http://127.0.0.1:8080
# For production: https://your-api-domain.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8080